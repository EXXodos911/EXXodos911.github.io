---
import SiteLayout from '../layouts/SiteLayout.astro';
import { formatPostDate, posts } from '../data/posts';

const orderedPosts = [...posts].sort((a, b) =>
  b.publishedAt.localeCompare(a.publishedAt)
);
---

<SiteLayout>
  <header class="page-header">
    <p class="eyebrow">Selected writing</p>
    <h1>Notes</h1>
    <p>Essays and observations on design, technology, and making things with intention.</p>
  </header>

  <section class="post-list" aria-label="Blog posts">
    {orderedPosts.map((post, index) => (
      <article class="post-row">
        <a href={`/blog/${post.slug}/`} aria-label={`Read ${post.title}`}>
          <div class="post-row__number" aria-hidden="true">
            {String(index + 1).padStart(2, '0')}
          </div>

          <div class="post-row__body">
            <h2>{post.title}</h2>
            <p>{post.description}</p>
            <div class="post-row__meta">
              <time datetime={post.publishedAt}>{formatPostDate(post.publishedAt)}</time>
              <span>{post.readingTime}</span>
            </div>
          </div>

          <span class="post-row__arrow" aria-hidden="true">↗</span>
        </a>
      </article>
    ))}
  </section>
</SiteLayout>
